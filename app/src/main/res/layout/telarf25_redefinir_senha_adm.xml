<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Fundo decorativo Premium -->

        <!-- Logo -->
        <ImageView
            android:id="@+id/imageLogoNovaSenha"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="40dp"
            android:layout_marginHorizontal="40dp"
            android:contentDescription="Logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- TÍTULO PRINCIPAL -->
        <TextView
            android:id="@+id/textTituloNovaSenha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Acesse sua Conta"
            android:textColor="@color/biblio_blue"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/imageLogoNovaSenha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- SUBTÍTULO -->
        <TextView
            android:id="@+id/textSubtituloNovaSenha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="Redefinir Senha"
            android:textColor="#415E5E"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/textTituloNovaSenha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- DESCRIÇÃO -->
        <TextView
            android:id="@+id/textDescricaoNovaSenha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="48dp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Preencha os campos abaixo com a sua nova senha."
            android:textColor="#5F6368"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/textSubtituloNovaSenha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- MENSAGENS DE ERRO (Agrupadas para fluidez) -->
        <LinearLayout
            android:id="@+id/layoutErrosSenha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/textDescricaoNovaSenha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/textErroSenha1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Campo obrigatório"
                android:textColor="@color/biblio_red"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/textErroSenha2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Campo obrigatório"
                android:textColor="@color/biblio_red"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- NOVA SENHA (Pill Style) -->
        <RelativeLayout
            android:id="@+id/layoutSenhaNova"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/layoutErrosSenha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/editSenhaNova"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input_pill"
                android:hint="Nova senha"
                android:importantForAutofill="no"
                android:inputType="textPassword"
                android:paddingStart="24dp"
                android:paddingEnd="56dp"
                android:textColor="@color/biblio_blue"
                android:textColorHint="#9E9E9E"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/iconOlhoSenhaNova"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:contentDescription="@string/desc_mostrar_ocultar_senha"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_eye_open"
                app:tint="@color/biblio_blue" />
        </RelativeLayout>

        <!-- CONFIRMAR SENHA (Pill Style) -->
        <RelativeLayout
            android:id="@+id/layoutConfirmarSenha"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/layoutSenhaNova"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/editConfirmarSenha"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input_pill"
                android:hint="Confirme a senha"
                android:importantForAutofill="no"
                android:inputType="textPassword"
                android:paddingStart="24dp"
                android:paddingEnd="56dp"
                android:textColor="@color/biblio_blue"
                android:textColorHint="#9E9E9E"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/iconOlhoConfirmarSenha"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:contentDescription="@string/desc_mostrar_ocultar_senha"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_eye_open"
                app:tint="@color/biblio_blue" />
        </RelativeLayout>

        <!-- REGRAS E AVISOS (Design Consolidado) -->
        <LinearLayout
            android:id="@+id/layoutAvisosSenha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/layoutConfirmarSenha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/textRegrasSenha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="2dp"
                android:text="• A senha deve conter pelo menos 8 caracteres\n• Um número\n• Uma letra maiúscula"
                android:textColor="@color/biblio_red"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/textErroSenhaIgual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="A senha é a mesma da antiga"
                android:textColor="@color/biblio_red"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/textErroSenhaDiferente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="As senhas estão diferentes, verifique!"
                android:textColor="@color/biblio_red"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- BOTÃO REDEFINIR (Pill Standard 56dp) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRedefinirSenha"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="32dp"
            android:text="Redefinir senha"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="28dp"
            app:elevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/layoutAvisosSenha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Espaço final -->
        <Space
            android:layout_width="0dp"
            android:layout_height="60dp"
            app:layout_constraintTop_toBottomOf="@id/buttonRedefinirSenha"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>