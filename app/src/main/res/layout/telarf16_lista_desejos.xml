<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER PREMIUM -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerListaDesejos"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO DECORATIVO -->
        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginStart="-120dp"
            android:layout_marginTop="-120dp"
            android:alpha="0.15"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO DO USUÁRIO -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFotoUsuarioDesejos"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="55dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imageUsuarioDesejos"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/nome_usuario"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardFotoUsuarioDesejos" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTEÚDO SCROLLÁVEL -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerListaDesejos">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="48dp">

            <!-- TÍTULO MINHA LISTA DE DESEJO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/titulo_minha_lista_desejo"
                    android:textColor="@color/biblio_dark"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="12dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="@color/biblio_blue" />
            </LinearLayout>

            <!-- CARD 1: VIDAS SECAS -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardD1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/coverD1"
                        android:layout_width="90dp"
                        android:layout_height="130dp"
                        app:cardCornerRadius="4dp"
                        app:cardElevation="2dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeWidth="0dp">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/vidas_secas_capa" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/titleD1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/label_vidas_secas"
                        android:textColor="@color/biblio_dark"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/menuD1"
                        app:layout_constraintStart_toEndOf="@id/coverD1"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/authorD1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/autor_graciliano"
                        android:textColor="#444444"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="@id/titleD1"
                        app:layout_constraintStart_toStartOf="@id/titleD1"
                        app:layout_constraintTop_toBottomOf="@id/titleD1" />

                    <TextView
                        android:id="@+id/dateD1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/data_exemplo_1"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="@id/titleD1"
                        app:layout_constraintTop_toBottomOf="@id/authorD1" />

                    <TextView
                        android:id="@+id/statusD1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Disponível "
                        android:textColor="#2E7D32"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/titleD1"
                        app:layout_constraintTop_toBottomOf="@id/dateD1" />

                    <!-- Ícone de Menu (3 pontos) -->
                    <TextView
                        android:id="@+id/menuD1"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="@string/menu_opcoes_simbolo"
                        android:textColor="@color/biblio_dark"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSuaLivraria1"
                        android:layout_width="120dp"
                        android:layout_height="45dp"
                        android:text="@string/btn_sua_livraria"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="#80CFD8"
                        android:textColor="@color/white"
                        app:cornerRadius="4dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/menuD1"
                        app:strokeColor="@color/biblio_dark"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAlugar1"
                        android:layout_width="120dp"
                        android:layout_height="45dp"
                        android:layout_marginTop="4dp"
                        android:text="@string/btn_alugar_livro"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="#80CFD8"
                        android:textColor="@color/white"
                        app:cornerRadius="4dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/btnSuaLivraria1"
                        app:strokeColor="@color/biblio_dark"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExcluir1"
                        android:layout_width="110dp"
                        android:layout_height="45dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/btn_remover"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="#D9534F"
                        app:cornerRadius="4dp"
                        app:layout_constraintStart_toStartOf="@id/titleD1"
                        app:layout_constraintTop_toBottomOf="@id/statusD1"
                        app:strokeColor="@color/biblio_dark"
                        app:strokeWidth="1dp" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD 2: O CEIFADOR -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardD2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/coverD2"
                        android:layout_width="90dp"
                        android:layout_height="130dp"
                        app:cardCornerRadius="4dp"
                        app:cardElevation="2dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:strokeWidth="0dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/o_alienista_capa"
                                android:alpha="0.4" />
                            <TextView
                                android:id="@+id/textForaEstoque2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:rotation="-45"
                                android:text="@string/label_fora_estoque"
                                android:textAlignment="center"
                                android:textColor="#8B0000"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:background="@color/white" />
                        </FrameLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/titleD2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/titulo_ceifador"
                        android:textColor="@color/biblio_dark"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/menuD2"
                        app:layout_constraintStart_toEndOf="@id/coverD2"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/authorD2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/autor_ceifador"
                        android:textColor="#444444"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="@id/titleD2"
                        app:layout_constraintStart_toStartOf="@id/titleD2"
                        app:layout_constraintTop_toBottomOf="@id/titleD2" />

                    <TextView
                        android:id="@+id/dateD2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/data_exemplo_3"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        app:layout_constraintStart_toStartOf="@id/titleD2"
                        app:layout_constraintTop_toBottomOf="@id/authorD2" />

                    <TextView
                        android:id="@+id/statusD2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Indisponível "
                        android:textColor="#C62828"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/titleD2"
                        app:layout_constraintTop_toBottomOf="@id/dateD2" />

                    <!-- Ícone de Menu (3 pontos) -->
                    <TextView
                        android:id="@+id/menuD2"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:text="@string/menu_opcoes_simbolo"
                        android:textColor="@color/biblio_dark"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSuaLivraria2"
                        android:layout_width="120dp"
                        android:layout_height="45dp"
                        android:text="@string/btn_sua_livraria"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="#80CFD8"
                        android:textColor="@color/white"
                        app:cornerRadius="4dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/menuD2"
                        app:strokeColor="@color/biblio_dark"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAlugar2"
                        android:layout_width="120dp"
                        android:layout_height="45dp"
                        android:layout_marginTop="4dp"
                        android:text="@string/btn_alugar_livro"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="#80CFD8"
                        android:textColor="@color/white"
                        app:cornerRadius="4dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/btnSuaLivraria2"
                        app:strokeColor="@color/biblio_dark"
                        app:strokeWidth="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExcluir2"
                        android:layout_width="110dp"
                        android:layout_height="45dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/btn_remover"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:backgroundTint="#D9534F"
                        app:cornerRadius="4dp"
                        app:layout_constraintStart_toStartOf="@id/titleD2"
                        app:layout_constraintTop_toBottomOf="@id/statusD2"
                        app:strokeColor="@color/biblio_dark"
                        app:strokeWidth="1dp" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
