<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- CAPA -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCapaDesejos"
            android:layout_width="90dp"
            android:layout_height="130dp"
            app:cardCornerRadius="4dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgCapaDesejos"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/osda"
                android:contentDescription="@string/desc_livro" />
        </com.google.android.material.card.MaterialCardView>

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/txtTituloDesejos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:textColor="@color/biblio_dark"
            android:textSize="17sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            tools:text="Título do Livro"
            app:layout_constraintEnd_toStartOf="@id/menuDesejos"
            app:layout_constraintStart_toEndOf="@id/cardCapaDesejos"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- AUTOR -->
        <TextView
            android:id="@+id/txtAutorDesejos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#616161"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Nome do Autor"
            app:layout_constraintEnd_toEndOf="@id/txtTituloDesejos"
            app:layout_constraintStart_toStartOf="@id/txtTituloDesejos"
            app:layout_constraintTop_toBottomOf="@id/txtTituloDesejos" />

        <!-- STATUS DISPONIBILIDADE -->
        <TextView
            android:id="@+id/txtStatusDesejos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Disponível"
            app:layout_constraintEnd_toEndOf="@id/txtTituloDesejos"
            app:layout_constraintStart_toStartOf="@id/txtTituloDesejos"
            app:layout_constraintTop_toBottomOf="@id/txtAutorDesejos" />

        <!-- MENU (3 pontos) -->
        <TextView
            android:id="@+id/menuDesejos"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="@string/menu_opcoes_simbolo"
            android:textColor="@color/biblio_dark"
            android:textSize="22sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- BOTÃO: SUA LIVRARIA -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSuaLivrariaDesejos"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:text="@string/btn_sua_livraria"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/biblio_dark"
            app:cornerRadius="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cardCapaDesejos"
            app:layout_constraintTop_toBottomOf="@id/txtStatusDesejos" />

        <!-- BOTÃO: ALUGAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlugarDesejos"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:text="@string/btn_alugar_livro"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cardCapaDesejos"
            app:layout_constraintTop_toBottomOf="@id/btnSuaLivrariaDesejos" />

        <!-- BOTÃO: EXCLUIR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExcluirDesejos"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:text="@string/btn_remover"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:backgroundTint="#D9534F"
            app:cornerRadius="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cardCapaDesejos"
            app:layout_constraintTop_toBottomOf="@id/btnAlugarDesejos"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
