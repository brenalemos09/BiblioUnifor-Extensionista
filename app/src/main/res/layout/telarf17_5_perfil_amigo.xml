<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER (Premium Standard) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerPerfilAmigo"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO DECORATIVO -->
        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginStart="-130dp"
            android:layout_marginTop="-130dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO PERFIL (Circular Standard) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFotoPerfilAmigo"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="55dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imagePerfilAmigo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />

        </com.google.android.material.card.MaterialCardView>

        <!-- EMAIL -->
        <TextView
            android:id="@+id/textEmailPerfilAmigo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="marquinhos@gmail.com"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardFotoPerfilAmigo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTEÚDO (Standard Padding 32dp) -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerPerfilAmigo"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <!-- NOME -->
            <TextView
                android:id="@+id/textTituloNomePerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome"
                android:textColor="#1B3434"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardNomePerfil"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <TextView
                    android:id="@+id/textNomePerfilAmigo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="24dp"
                    android:text="Marcos Antônio"
                    android:textColor="#415E5E"
                    android:textSize="16sp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- USUÁRIO -->
            <TextView
                android:id="@+id/textTituloUsuarioPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Usuário"
                android:textColor="#1B3434"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUsuarioPerfil"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <TextView
                    android:id="@+id/textUsuarioPerfilAmigo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="24dp"
                    android:text="Marquinhoss302890"
                    android:textColor="#415E5E"
                    android:textSize="16sp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- BIO -->
            <TextView
                android:id="@+id/textTituloBioPerfil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Bio"
                android:textColor="#1B3434"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBioPerfil"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <TextView
                    android:id="@+id/textBioPerfilAmigo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="top"
                    android:padding="16dp"
                    android:text="Ler é legal."
                    android:textColor="#415E5E"
                    android:textSize="16sp" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>