<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLivro"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_marginStart="-100dp"
            android:layout_marginTop="-150dp"
            android:alpha="0.12"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCapaLivro"
            android:layout_width="115dp"
            android:layout_height="165dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="45dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="12dp"
            app:strokeWidth="2dp"
            app:strokeColor="#25FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgCapaLivroDetalhe"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/osda"
                tools:src="@drawable/o_alienista_capa"
                android:contentDescription="@string/desc_capa_livro_crud" />

        </com.google.android.material.card.MaterialCardView>

        <EditText
            android:id="@+id/editTituloLivro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="55dp"
            android:layout_marginEnd="8dp"
            android:background="@android:color/transparent"
            android:enabled="false"
            android:fontFamily="sans-serif-black"
            android:text=""
            tools:text="O Alienista"
            android:textColor="@color/white"
            android:textSize="26sp"
            app:layout_constraintEnd_toStartOf="@id/btnEditTitulo"
            app:layout_constraintStart_toEndOf="@id/cardCapaLivro"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnEditTitulo"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="24dp"
            android:src="@drawable/ic_edit_pencil"
            app:layout_constraintBottom_toBottomOf="@id/editTituloLivro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/editTituloLivro"
            app:tint="@color/white" />

        <EditText
            android:id="@+id/editAutorLivro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:alpha="0.8"
            android:background="@android:color/transparent"
            android:enabled="false"
            android:fontFamily="sans-serif-medium"
            android:text="Machado de Assis"
            android:textColor="@color/white"
            android:textSize="18sp"
            app:layout_constraintEnd_toStartOf="@id/btnEditAutor"
            app:layout_constraintStart_toStartOf="@id/editTituloLivro"
            app:layout_constraintTop_toBottomOf="@id/editTituloLivro" />

        <ImageView
            android:id="@+id/btnEditAutor"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="24dp"
            android:alpha="0.8"
            android:src="@drawable/ic_edit_pencil"
            app:layout_constraintBottom_toBottomOf="@id/editAutorLivro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/editAutorLivro"
            app:tint="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApagarMidia"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.02"
            android:text="Apagar Mídia"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="@color/biblio_red"
            app:cornerRadius="16dp"
            app:elevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/editTituloLivro"
            app:layout_constraintTop_toBottomOf="@id/editAutorLivro" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLivro">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="64dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-black"
                        android:text="Sobre"
                        android:textColor="@color/black"
                        android:textSize="26sp" />

                    <ImageView
                        android:id="@+id/btnEditDescricao"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:src="@drawable/ic_edit_pencil"
                        app:tint="@color/black" />
                </LinearLayout>

                <EditText
                    android:id="@+id/editDescricaoLivro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@android:color/transparent"
                    android:enabled="false"
                    android:fontFamily="sans-serif"
                    android:lineSpacingExtra="8dp"
                    android:text="Machado de Assis, neste livro, propõe a seguinte pergunta: quem é louco? Conheça a história do médico Simão Bacamarte, dedicado e estudioso da mente humana, que decide construir um hospício para tratar os doentes mentais na pequena cidade de Itaguaí a casa verde. Quem entra e quem fica de fora? Surpreenda-se com o final."
                    android:textColor="#555555"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Língua: "
                        android:textColor="@color/black"
                        android:textSize="16sp" />
                    <EditText
                        android:id="@+id/editLingua"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:text="Português"
                        android:textColor="#777777"
                        android:textSize="16sp" />
                    <ImageView
                        android:id="@+id/btnEditLingua"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.6"
                        android:src="@drawable/ic_edit_pencil"
                        app:tint="@color/black" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Editora: "
                        android:textColor="@color/black"
                        android:textSize="16sp" />
                    <EditText
                        android:id="@+id/editEditora"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:text="Intrínseca"
                        android:textColor="#777777"
                        android:textSize="16sp" />
                    <ImageView
                        android:id="@+id/btnEditEditora"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.6"
                        android:src="@drawable/ic_edit_pencil"
                        app:tint="@color/black" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Dimensão: "
                        android:textColor="@color/black"
                        android:textSize="16sp" />
                    <EditText
                        android:id="@+id/editDimensao"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:text="15.24 x 0.51 x 22.86 cm"
                        android:textColor="#777777"
                        android:textSize="16sp" />
                    <ImageView
                        android:id="@+id/btnEditDimensao"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.6"
                        android:src="@drawable/ic_edit_pencil"
                        app:tint="@color/black" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="ISBN-10: "
                        android:textColor="@color/black"
                        android:textSize="16sp" />
                    <EditText
                        android:id="@+id/editISBN10"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:text="856356093X"
                        android:textColor="#777777"
                        android:textSize="16sp" />
                    <ImageView
                        android:id="@+id/btnEditISBN10"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.6"
                        android:src="@drawable/ic_edit_pencil"
                        app:tint="@color/black" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="ISBN-13: "
                        android:textColor="@color/black"
                        android:textSize="16sp" />
                    <EditText
                        android:id="@+id/editISBN13"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:text="978-8563560933"
                        android:textColor="#777777"
                        android:textSize="16sp" />
                    <ImageView
                        android:id="@+id/btnEditISBN13"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.6"
                        android:src="@drawable/ic_edit_pencil"
                        app:tint="@color/black" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Data: "
                        android:textColor="@color/black"
                        android:textSize="16sp" />
                    <EditText
                        android:id="@+id/editData"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:text="18 dezembro 2019"
                        android:textColor="#777777"
                        android:textSize="16sp" />
                    <ImageView
                        android:id="@+id/btnEditData"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.6"
                        android:src="@drawable/ic_edit_pencil"
                        app:tint="@color/black" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Páginas: "
                        android:textColor="@color/black"
                        android:textSize="16sp" />
                    <EditText
                        android:id="@+id/editPaginas"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:text="80"
                        android:textColor="#777777"
                        android:textSize="16sp" />
                    <ImageView
                        android:id="@+id/btnEditPaginas"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.6"
                        android:src="@drawable/ic_edit_pencil"
                        app:tint="@color/black" />
                </LinearLayout>

                <!-- ── Categoria ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Categoria: "
                        android:textColor="@color/black"
                        android:textSize="16sp" />
                    <EditText
                        android:id="@+id/editCategoria"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:text=""
                        android:textColor="#777777"
                        android:textSize="16sp"
                        android:contentDescription="Categoria do livro" />
                    <ImageView
                        android:id="@+id/btnEditCategoria"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.6"
                        android:src="@drawable/ic_edit_pencil"
                        android:contentDescription="Editar categoria"
                        app:tint="@color/black" />
                </LinearLayout>

                <!-- ── Link da Capa (URL) ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Link Capa: "
                        android:textColor="@color/black"
                        android:textSize="16sp" />
                    <EditText
                        android:id="@+id/editLinkCapa"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:inputType="textUri"
                        android:text=""
                        android:textColor="#777777"
                        android:textSize="14sp"
                        android:contentDescription="Link da imagem de capa" />
                    <ImageView
                        android:id="@+id/btnEditLinkCapa"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.6"
                        android:src="@drawable/ic_edit_pencil"
                        android:contentDescription="Editar link da capa"
                        app:tint="@color/black" />
                </LinearLayout>

                <!-- ── Link PDF (URL) ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Link PDF: "
                        android:textColor="@color/black"
                        android:textSize="16sp" />
                    <EditText
                        android:id="@+id/editLinkPdf"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:inputType="textUri"
                        android:text=""
                        android:textColor="#777777"
                        android:textSize="14sp"
                        android:contentDescription="Link do PDF" />
                    <ImageView
                        android:id="@+id/btnEditLinkPdf"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.6"
                        android:src="@drawable/ic_edit_pencil"
                        android:contentDescription="Editar link do PDF"
                        app:tint="@color/black" />
                </LinearLayout>

                <!-- ── Link Audiobook (URL) ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="Link Audiobook: "
                        android:textColor="@color/black"
                        android:textSize="16sp" />
                    <EditText
                        android:id="@+id/editLinkAudiobook"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:inputType="textUri"
                        android:text=""
                        android:textColor="#777777"
                        android:textSize="14sp"
                        android:contentDescription="Link do Audiobook" />
                    <ImageView
                        android:id="@+id/btnEditLinkAudiobook"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:alpha="0.6"
                        android:src="@drawable/ic_edit_pencil"
                        android:contentDescription="Editar link do Audiobook"
                        app:tint="@color/black" />
                </LinearLayout>

                <!-- ── Braille (Checkbox) ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:text="Disponível em Braille"
                        android:textColor="@color/black"
                        android:textSize="16sp" />
                    <CheckBox
                        android:id="@+id/checkBrailleInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="Disponível em Braille" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="Exemplares: "
                        android:textColor="@color/black"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="10/30"
                        android:textColor="@color/biblio_blue"
                        android:textSize="18sp" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnDiminuirExemplares"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="21dp"
                        app:cardElevation="2dp"
                        app:rippleColor="#15000000"
                        app:strokeColor="#10000000"
                        app:strokeWidth="1dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="▼"
                            android:textColor="@color/black"
                            android:textSize="14sp" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/textExemplaresTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:fontFamily="sans-serif-black"
                        android:text="30"
                        android:textColor="@color/black"
                        android:textSize="22sp" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnAumentarExemplares"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="21dp"
                        app:cardElevation="2dp"
                        app:rippleColor="#15000000"
                        app:strokeColor="#10000000"
                        app:strokeWidth="1dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="▲"
                            android:textColor="@color/black"
                            android:textSize="14sp" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginVertical="32dp"
                android:background="#F2F2F2" />

            <LinearLayout
                android:id="@+id/containerAvaliacoes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp">

                <TextView
                    android:id="@+id/textSemAvaliacoes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhuma avaliação para este livro."
                    android:textColor="#999999"
                    android:textSize="15sp"
                    android:gravity="center"
                    android:layout_marginTop="20dp"
                    android:visibility="gone" />

                <!-- As avaliações serão inseridas aqui dinamicamente -->

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>