<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- ===================================================== -->
    <!-- HEADER PREMIUM MODERNO -->
    <!-- ===================================================== -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLivro"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO DECORATIVO DESIGNER -->
        <View
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:layout_marginStart="-100dp"
            android:layout_marginTop="-150dp"
            android:alpha="0.12"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- CAPA DO LIVRO COM BORDAS SUAVES -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCapaLivro"
            android:layout_width="115dp"
            android:layout_height="165dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="45dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="12dp"
            app:strokeWidth="2dp"
            app:strokeColor="#25FFFFFF"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/o_alienista_capa" />

        </com.google.android.material.card.MaterialCardView>

        <!-- TÍTULO IMPACTANTE -->
        <EditText
            android:id="@+id/editTituloLivro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="55dp"
            android:layout_marginEnd="8dp"
            android:text="O Alienista"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:fontFamily="sans-serif-black"
            android:background="@android:color/transparent"
            android:enabled="false"
            app:layout_constraintEnd_toStartOf="@id/btnEditTitulo"
            app:layout_constraintStart_toEndOf="@id/cardCapaLivro"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnEditTitulo"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="24dp"
            android:src="@drawable/ic_edit_pencil"
            app:tint="@color/white"
            app:layout_constraintBottom_toBottomOf="@id/editTituloLivro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/editTituloLivro" />

        <!-- AUTOR ELEGANTE -->
        <EditText
            android:id="@+id/editAutorLivro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:text="Machado de Assis"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:alpha="0.8"
            android:fontFamily="sans-serif-medium"
            android:background="@android:color/transparent"
            android:enabled="false"
            app:layout_constraintEnd_toStartOf="@id/btnEditAutor"
            app:layout_constraintStart_toStartOf="@id/editTituloLivro"
            app:layout_constraintTop_toBottomOf="@id/editTituloLivro" />

        <ImageView
            android:id="@+id/btnEditAutor"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="24dp"
            android:src="@drawable/ic_edit_pencil"
            app:tint="@color/white"
            android:alpha="0.8"
            app:layout_constraintBottom_toBottomOf="@id/editAutorLivro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/editAutorLivro" />

        <!-- BOTÃO APAGAR (PILL-SHAPE PERFEITO) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApagarMidia"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="24dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.02"
            android:text="Apagar Mídia"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:backgroundTint="@color/biblio_red"
            app:cornerRadius="28dp"
            app:elevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/editTituloLivro"
            app:layout_constraintTop_toBottomOf="@id/editAutorLivro"
            app:rippleColor="#40FFFFFF" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ===================================================== -->
    <!-- CONTEÚDO FLUIDO -->
    <!-- ===================================================== -->

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLivro">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="48dp">

            <!-- SEÇÃO SOBRE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sobre"
                        android:textColor="@color/black"
                        android:textSize="26sp"
                        android:fontFamily="sans-serif-black" />
                    <ImageView
                        android:id="@+id/btnEditDescricao"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_edit_pencil"
                        app:tint="@color/black" />
                </LinearLayout>

                <EditText
                    android:id="@+id/editDescricaoLivro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="8dp"
                    android:text="Machado de Assis, neste livro, propõe a seguinte pergunta: quem é louco? Conheça a história do médico Simão Bacamarte, dedicado e estudioso da mente humana, que decide construir um hospício para tratar os doentes mentais na pequena cidade de Itaguaí a casa verde. Quem entra e quem fica de fora? Surpreenda-se com o final."
                    android:textColor="#555555"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif"
                    android:background="@android:color/transparent"
                    android:enabled="false" />
            </LinearLayout>

            <!-- LISTA DE DETALHES REFINADA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="28dp">

                <!-- ITEM LÍNGUA -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Língua: "
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-medium" />
                    <EditText
                        android:id="@+id/editLingua"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Português"
                        android:textColor="#777777"
                        android:textSize="17sp"
                        android:background="@android:color/transparent"
                        android:enabled="false" />
                    <ImageView
                        android:id="@+id/btnEditLingua"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_edit_pencil"
                        android:alpha="0.6"
                        app:tint="@color/black" />
                </LinearLayout>

                <!-- ITEM EDITORA -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Editora: "
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-medium" />
                    <EditText
                        android:id="@+id/editEditora"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Intrínseca"
                        android:textColor="#777777"
                        android:textSize="17sp"
                        android:background="@android:color/transparent"
                        android:enabled="false" />
                    <ImageView
                        android:id="@+id/btnEditEditora"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_edit_pencil"
                        android:alpha="0.6"
                        app:tint="@color/black" />
                </LinearLayout>

                <!-- ITEM DIMENSÃO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dimensão: "
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-medium" />
                    <EditText
                        android:id="@+id/editDimensao"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="15.24 x 0.51 x 22.86 cm"
                        android:textColor="#777777"
                        android:textSize="17sp"
                        android:background="@android:color/transparent"
                        android:enabled="false" />
                    <ImageView
                        android:id="@+id/btnEditDimensao"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_edit_pencil"
                        android:alpha="0.6"
                        app:tint="@color/black" />
                </LinearLayout>

                <!-- ITEM ISBN-10 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ISBN-10: "
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-medium" />
                    <EditText
                        android:id="@+id/editISBN10"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="856356093X"
                        android:textColor="#777777"
                        android:textSize="17sp"
                        android:background="@android:color/transparent"
                        android:enabled="false" />
                    <ImageView
                        android:id="@+id/btnEditISBN10"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_edit_pencil"
                        android:alpha="0.6"
                        app:tint="@color/black" />
                </LinearLayout>

                <!-- ITEM ISBN-13 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ISBN-13: "
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-medium" />
                    <EditText
                        android:id="@+id/editISBN13"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="978-8563560933"
                        android:textColor="#777777"
                        android:textSize="17sp"
                        android:background="@android:color/transparent"
                        android:enabled="false" />
                    <ImageView
                        android:id="@+id/btnEditISBN13"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_edit_pencil"
                        android:alpha="0.6"
                        app:tint="@color/black" />
                </LinearLayout>

                <!-- ITEM DATA -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Data: "
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-medium" />
                    <EditText
                        android:id="@+id/editData"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="18 dezembro 2019"
                        android:textColor="#777777"
                        android:textSize="17sp"
                        android:background="@android:color/transparent"
                        android:enabled="false" />
                    <ImageView
                        android:id="@+id/btnEditData"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_edit_pencil"
                        android:alpha="0.6"
                        app:tint="@color/black" />
                </LinearLayout>

                <!-- ITEM PÁGINAS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Páginas: "
                        android:textColor="@color/black"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-medium" />
                    <EditText
                        android:id="@+id/editPaginas"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="80"
                        android:textColor="#777777"
                        android:textSize="17sp"
                        android:background="@android:color/transparent"
                        android:enabled="false" />
                    <ImageView
                        android:id="@+id/btnEditPaginas"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_edit_pencil"
                        android:alpha="0.6"
                        app:tint="@color/black" />
                </LinearLayout>

                <!-- EXEMPLARES (ESTILO PILL MODERNO) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Exemplares: "
                        android:textColor="@color/black"
                        android:textSize="19sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10/30"
                        android:textColor="@color/biblio_blue"
                        android:textSize="19sp"
                        android:fontFamily="sans-serif-black" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <!-- MENOS (CÍRCULO ELEVADO) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnDiminuirExemplares"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="21dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#10000000"
                        app:rippleColor="#15000000">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="▼"
                            android:textColor="@color/black"
                            android:textSize="14sp" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/textExemplaresTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:text="30"
                        android:textColor="@color/black"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black" />

                    <!-- MAIS (CÍRCULO ELEVADO) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnAumentarExemplares"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="21dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#10000000"
                        app:rippleColor="#15000000">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="▲"
                            android:textColor="@color/black"
                            android:textSize="14sp" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

            <!-- DIVISÓRIA ELEGANTE -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginVertical="40dp"
                android:layout_marginHorizontal="28dp"
                android:background="#F2F2F2" />

            <!-- SEÇÃO COMENTÁRIOS COM FEEDBACK VISUAL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="28dp">

                <!-- COMENTÁRIO 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="@color/white">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/user_placeholder" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:text="Ronaldo Alves"
                        android:textColor="@color/black"
                        android:textSize="19sp"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="5dp"
                    android:text="é um livro ótimo e engraçado e me parece fazer mais uma crítica à relação das pessoas com o poder e do conceito de loucura"
                    android:textColor="#666666"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="32dp"
                    android:background="#F8F8F8" />

                <!-- COMENTÁRIO 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="2dp"
                        app:strokeColor="@color/white">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/user_placeholder" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:text="Ronaldo Alves"
                        android:textColor="@color/black"
                        android:textSize="19sp"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="5dp"
                    android:text="Lembro de ter sido obrigado a ler O Alienista no ensino médio, junto com outras obras igualmente entediantes como: O Guarani, Iracema e Quincas Borba. Sinceramente, não me recordo bem da trama."
                    android:textColor="#666666"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>