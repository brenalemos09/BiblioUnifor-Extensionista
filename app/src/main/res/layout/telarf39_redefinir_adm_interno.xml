<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F7">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerRedefinir"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginStart="-60dp"
            android:layout_marginTop="-60dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/btnVoltar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="36dp"
            android:padding="8dp"
            android:src="@drawable/ic_chevron_left"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Redefinir Senha"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerRedefinir">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- SENHA ATUAL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Senha atual"
                android:textColor="@color/biblio_blue"
                android:textSize="16sp"
                android:textStyle="bold" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_pill">

                <EditText
                    android:id="@+id/editSenhaAtual"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Sua senha atual"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:paddingEnd="50dp"
                    android:textColor="#000000" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/eyeSenhaAtual"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:padding="12dp"
                    android:src="@drawable/ic_eye_closed"
                    app:tint="@color/biblio_blue" />
            </RelativeLayout>

            <TextView
                android:id="@+id/errorSenhaAtual"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="4dp"
                android:text="Senha inválida"
                android:textColor="@color/biblio_red"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- NOVA SENHA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Nova senha"
                android:textColor="@color/biblio_blue"
                android:textSize="16sp"
                android:textStyle="bold" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_pill">

                <EditText
                    android:id="@+id/editNovaSenha"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Mínimo 8 caracteres"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:paddingEnd="50dp"
                    android:textColor="#000000" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/eyeNovaSenha"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:padding="12dp"
                    android:src="@drawable/ic_eye_closed"
                    app:tint="@color/biblio_blue" />
            </RelativeLayout>

            <TextView
                android:id="@+id/errorNovaSenha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="4dp"
                android:text="Mínimo 8 caracteres"
                android:textColor="@color/biblio_red"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- CONFIRMAR SENHA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Confirmar senha"
                android:textColor="@color/biblio_blue"
                android:textSize="16sp"
                android:textStyle="bold" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_pill">

                <EditText
                    android:id="@+id/editConfirmarSenha"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:hint="Repita a nova senha"
                    android:inputType="textPassword"
                    android:paddingHorizontal="16dp"
                    android:paddingEnd="50dp"
                    android:textColor="#000000" />

                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/eyeConfirmarSenha"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:padding="12dp"
                    android:src="@drawable/ic_eye_closed"
                    app:tint="@color/biblio_blue" />
            </RelativeLayout>

            <TextView
                android:id="@+id/errorConfirmarSenha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginTop="4dp"
                android:text="As senhas não coincidem"
                android:textColor="@color/biblio_red"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- BOTÃO SALVAR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSalvarAlteracoes"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="Salvar Alterações"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="30dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>