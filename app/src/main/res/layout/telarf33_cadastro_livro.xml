<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- ===================================================== -->
    <!-- HEADER -->
    <!-- ===================================================== -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerAdicionarMidia"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO DECORATIVO -->
        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginStart="-90dp"
            android:layout_marginTop="-90dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- CÍRCULO DECORATIVO -->
        <View
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginEnd="-55dp"
            android:layout_marginTop="-25dp"
            android:alpha="0.10"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- TÍTULO -->

        <TextView
            android:id="@+id/textTituloAdicionarMidia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="78dp"
            android:text="@string/titulo_adicionar_midia"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ===================================================== -->
    <!-- CONTEÚDO -->
    <!-- ===================================================== -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerAdicionarMidia">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="30dp">

            <!-- ================================================= -->
            <!-- TÍTULO -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/label_titulo"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="1dp">

                <EditText
                    android:id="@+id/editTituloLivro"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:hint="@string/hint_nome_titulo"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/black"
                    android:textColorHint="#8A8A8A"
                    android:textSize="15sp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================= -->
            <!-- AUTOR -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/label_autor"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="1dp">

                <EditText
                    android:id="@+id/editAutorLivro"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:hint="@string/hint_nome_autor"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/black"
                    android:textColorHint="#8A8A8A"
                    android:textSize="15sp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================= -->
            <!-- ISBN -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/label_isbn"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="1dp">

                <EditText
                    android:id="@+id/editCodigoIsbn"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:hint="@string/hint_isbn"
                    android:inputType="number"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/black"
                    android:textColorHint="#8A8A8A"
                    android:textSize="15sp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================= -->
            <!-- DATA -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/label_data_publicacao_livro"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="1dp">

                <EditText
                    android:id="@+id/editDataPublicacao"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center_vertical"
                    android:hint="dd/mm/aaaa"
                    android:inputType="text"
                    android:digits="0123456789/"
                    android:maxLength="10"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/black"
                    android:textColorHint="#8A8A8A"
                    android:textSize="15sp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================= -->
            <!-- QUANTIDADE -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/label_quantidade_exemplares"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="22dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="1dp">

                <EditText
                    android:id="@+id/editQuantidadeExemplares"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:hint="@string/hint_quantidade_exemplares"
                    android:inputType="number"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/black"
                    android:textColorHint="#8A8A8A"
                    android:textSize="15sp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================= -->
            <!-- BOTÃO -->
            <!-- ================================================= -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditarMaisInformacoes2"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_editar_mais_infos"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="28dp"
                app:elevation="4dp" />

            <!-- ================================================= -->
            <!-- ERRO -->
            <!-- ================================================= -->

            <TextView
                android:id="@+id/textErroCampos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/erro_preencha_campos"
                android:textColor="#D9534F"
                android:textSize="16sp"
                android:visibility="visible" />

        </LinearLayout>

    </ScrollView>



</androidx.constraintlayout.widget.ConstraintLayout>