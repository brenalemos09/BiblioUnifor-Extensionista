<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg"
    tools:context=".adm.TelaRF33CadastroDeLivros">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerAdicionarMidia"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginStart="-90dp"
            android:layout_marginTop="-90dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginTop="-25dp"
            android:layout_marginEnd="-55dp"
            android:alpha="0.10"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textTituloAdicionarMidia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_adicionar_midia"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerAdicionarMidia">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/label_titulo"
                android:textColor="@color/biblio_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editTituloLivro"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_nome_titulo"
                android:paddingHorizontal="20dp"
                android:textColor="@color/black"
                android:textColorHint="#9E9E9E"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/label_autor"
                android:textColor="@color/biblio_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editAutorLivro"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_nome_autor"
                android:paddingHorizontal="20dp"
                android:textColor="@color/black"
                android:textColorHint="#9E9E9E"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/label_isbn"
                android:textColor="@color/biblio_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editCodigoIsbn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_isbn"
                android:inputType="number"
                android:paddingHorizontal="20dp"
                android:textColor="@color/black"
                android:textColorHint="#9E9E9E"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/label_data_publicacao_livro"
                android:textColor="@color/biblio_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editDataPublicacao"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_input"
                android:digits="0123456789/"
                android:hint="dd/mm/aaaa"
                android:inputType="text"
                android:maxLength="10"
                android:paddingHorizontal="20dp"
                android:textColor="@color/black"
                android:textColorHint="#9E9E9E"
                android:textSize="16sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/label_quantidade_exemplares"
                android:textColor="@color/biblio_dark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editQuantidadeExemplares"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_quantidade_exemplares"
                android:inputType="number"
                android:paddingHorizontal="20dp"
                android:textColor="@color/black"
                android:textColorHint="#9E9E9E"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditarMaisInformacoes2"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_editar_mais_infos"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="16dp"
                app:elevation="0dp" />

            <TextView
                android:id="@+id/textErroCampos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:text="@string/erro_preencha_campos"
                android:textColor="@color/biblio_red"
                android:textSize="14sp"
                android:visibility="gone"
                tools:visibility="visible" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>