<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutPopupPrazoRenovacao"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="32dp"
    android:background="@drawable/bg_dialog_rounded">

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/textTituloPopupPrazoRenovacao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="ATENÇÃO!"
        android:textColor="@color/biblio_detalhes"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- MENSAGEM -->
    <TextView
        android:id="@+id/textMensagemPopupPrazoRenovacao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Você está fora do prazo de renovação desse livro."
        android:textColor="@color/biblio_detalhes"
        android:textSize="18sp" />

    <!-- BOTÃO -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonVoltarPopupPrazoRenovacao"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="Voltar"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="28dp"
        app:elevation="2dp" />

</LinearLayout>