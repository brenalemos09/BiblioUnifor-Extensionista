<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/biblio_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Fundo -->

        <!-- Logo -->
        <ImageView
            android:id="@+id/imageLogoNovaSenha"
            android:layout_width="300dp"
            android:layout_height="150dp"
            android:layout_marginTop="45dp"
            android:adjustViewBounds="true"
            android:contentDescription="logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Título -->
        <TextView
            android:id="@+id/textTituloNovaSenha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Acesse sua Conta"
            android:textColor="@color/black"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/imageLogoNovaSenha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Subtítulo -->
        <TextView
            android:id="@+id/textSubtituloNovaSenha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="45dp"
            android:text="Redefinir Senha"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/textTituloNovaSenha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Descrição -->
        <TextView
            android:id="@+id/textDescricaoNovaSenha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="48dp"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="Preencha os campos abaixo com a sua nova senha."
            android:textColor="#5F6368"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/textSubtituloNovaSenha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Campo obrigatório -->
        <TextView
            android:id="@+id/textErroSenha1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="40dp"
            android:text="Campo obrigatório"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/textDescricaoNovaSenha"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Nova senha -->
        <RelativeLayout
            android:id="@+id/layoutSenhaNova"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/textErroSenha1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/editSenhaNova"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input_pill"
                android:hint="Nova senha"
                android:importantForAutofill="no"
                android:inputType="textPassword"
                android:paddingStart="24dp"
                android:paddingEnd="56dp"
                android:textColor="@color/black"
                android:textColorHint="#9E9E9E" />

            <ImageView
                android:id="@+id/iconOlhoSenhaNova"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:contentDescription="@string/desc_mostrar_ocultar_senha"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_eye_open"
                app:tint="@color/biblio_blue" />
        </RelativeLayout>

        <!-- Campo obrigatório -->
        <TextView
            android:id="@+id/textErroSenha2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="20dp"
            android:text="Campo obrigatório"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layoutSenhaNova"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Confirmar senha -->
        <RelativeLayout
            android:id="@+id/layoutConfirmarSenha"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/textErroSenha2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/editConfirmarSenha"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input_pill"
                android:hint="Confirme a senha"
                android:importantForAutofill="no"
                android:inputType="textPassword"
                android:paddingStart="24dp"
                android:paddingEnd="56dp"
                android:textColor="@color/black"
                android:textColorHint="#9E9E9E" />

            <ImageView
                android:id="@+id/iconOlhoConfirmarSenha"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:contentDescription="@string/desc_mostrar_ocultar_senha"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_eye_open"
                app:tint="@color/biblio_blue" />
        </RelativeLayout>

        <!-- Regras -->
        <TextView
            android:id="@+id/textRegrasSenha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="24dp"
            android:text="• A senha deve conter pelo menos 8 caracteres&#10;• Um número&#10;• Uma letra maiúscula"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layoutConfirmarSenha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Erro antiga -->
        <TextView
            android:id="@+id/textErroSenhaIgual"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="14dp"
            android:text="A senha é a mesma da antiga"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/textRegrasSenha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Erro diferente -->
        <TextView
            android:id="@+id/textErroSenhaDiferente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="4dp"
            android:text="As senhas estão diferentes, verifique!"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/textErroSenhaIgual"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botão -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRedefinirSenha"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="36dp"
            android:layout_marginBottom="32dp"
            android:text="Redefinir senha"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="28dp"
            app:elevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/textErroSenhaDiferente"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>