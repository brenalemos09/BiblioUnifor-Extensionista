<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- HEADER CLEAN -->
    <LinearLayout
        android:id="@+id/headerLivro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:background="@color/white"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardCapaLivro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/imageLivroDetalhes"
                android:layout_width="100dp"
                android:layout_height="145dp"
                android:scaleType="centerCrop"
                android:src="@drawable/osda"
                android:contentDescription="@string/desc_livro" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/layoutInfoLivro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="20dp">

            <TextView
                android:id="@+id/textTituloLivro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/titulo_livro"
                android:textColor="@color/biblio_dark"
                android:textStyle="bold"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/textAutorLivro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/autor_machado"
                android:textColor="#757575"
                android:textSize="18sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollConteudo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/biblio_bg"
        app:layout_constraintTop_toBottomOf="@id/headerLivro"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/layoutPrincipal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:orientation="vertical">

            <!-- LINHA 1: LISTA E LIVRARIA -->
            <LinearLayout
                android:id="@+id/layoutAcoesSecundarias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonListaDesejos"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="@string/btn_lista_desejos"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    app:strokeColor="@color/biblio_detalhes"
                    android:textColor="@color/biblio_dark"
                    app:cornerRadius="25dp"/>

                <Space
                    android:layout_width="12dp"
                    android:layout_height="wrap_content"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSuaLivraria"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="@string/btn_sua_livraria"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    app:strokeColor="@color/biblio_detalhes"
                    android:textColor="@color/biblio_dark"
                    app:cornerRadius="25dp"/>
            </LinearLayout>

            <!-- ESTADO DA LEITURA -->
            <TextView
                android:id="@+id/labelStatusLeitura"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_status_leitura"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/layoutStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonNaoLido"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/label_btn_nao_lido"
                    android:textAllCaps="false"
                    android:backgroundTint="#F0F7FF"
                    android:textColor="@color/biblio_dark"
                    app:cornerRadius="24dp"/>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="wrap_content"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonLendo"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/label_btn_lendo"
                    android:textAllCaps="false"
                    android:backgroundTint="#E1F0FF"
                    android:textColor="@color/biblio_dark"
                    app:cornerRadius="24dp"/>

                <Space
                    android:layout_width="8dp"
                    android:layout_height="wrap_content"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonLido"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="@string/label_btn_lido"
                    android:textAllCaps="false"
                    android:backgroundTint="#F0F7FF"
                    android:textColor="@color/biblio_dark"
                    app:cornerRadius="24dp"/>
            </LinearLayout>

            <!-- AÇÕES DE AQUISIÇÃO -->
            <LinearLayout
                android:id="@+id/layoutAcoesAquisicao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSolicitar"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="@string/btn_solicitar"
                    android:textAllCaps="false"
                    android:textColor="@color/biblio_dark"
                    app:backgroundTint="#D1E9FF"
                    app:cornerRadius="12dp"
                    app:elevation="0dp"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonLer"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="12dp"
                android:text="@string/btn_ler_agora"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="30dp"
                app:elevation="2dp"/>

            <!-- NOTA -->
            <TextView
                android:id="@+id/labelSuaNota"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_sua_nota"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/biblio_dark"
                android:layout_marginTop="32dp"/>

            <RatingBar
                android:id="@+id/ratingBarLivro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:rating="4"
                android:scaleX="0.8"
                android:scaleY="0.8"
                android:transformPivotX="0dp"
                android:progressTint="@color/biblio_detalhes"
                android:layout_marginTop="4dp"
                style="?android:attr/ratingBarStyleIndicator"/>

            <!-- DISPONIBILIDADE -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDisponibilidade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E0E0E0">

                <LinearLayout
                    android:id="@+id/layoutDispInterno"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/statusIndicator"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/circle_green"
                        android:backgroundTint="#4CAF50"/>

                    <TextView
                        android:id="@+id/textDisponivel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/label_disponivel_aluguel"
                        android:textColor="#4CAF50"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                    <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/textEstoque"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_unidades_estoque"
                        android:textColor="#757575"
                        android:textSize="13sp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SINOPSE -->
            <TextView
                android:id="@+id/labelSinopse"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_sinopse_title"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/biblio_dark"
                android:layout_marginTop="32dp"/>

            <TextView
                android:id="@+id/textSobreLivro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sinopse_alienista"
                android:textColor="#616161"
                android:textSize="15sp"
                android:lineSpacingExtra="5sp"
                android:layout_marginTop="12dp"/>

            <!-- CATEGORIAS -->
            <LinearLayout
                android:id="@+id/layoutCategorias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="32dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonGenero"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/genero_ficcao_psicologica"
                    android:textAllCaps="false"
                    android:textColor="@color/biblio_dark"
                    android:backgroundTint="#F5F5F5"
                    app:cornerRadius="16dp"/>

                <Space
                    android:layout_width="12dp"
                    android:layout_height="wrap_content" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonVerMais"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_ver_mais_detalhes"
                    android:textAllCaps="false"
                    android:textColor="@color/biblio_blue"/>
            </LinearLayout>

            <TextView
                android:id="@+id/textAvaliacoes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_avaliacoes_count"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/biblio_dark"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="40dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>