<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="24dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="32dp"
    app:cardElevation="12dp">

    <!-- ====================================================== -->
    <!-- CONTEÚDO REFINADO -->
    <!-- ====================================================== -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detalhes da Pendência"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/textInfoPendencia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Livro: O Alienista\nUsuário: Ronaldo Alves\nPrazo: 18/12/2019\nStatus: Retirada Pendente"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"/>

        <!-- NOTIFICAR ATRASO -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNotificarAtraso"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="12dp"
            android:text="Notificar atraso"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="27dp"
            app:elevation="2dp" />

        <!-- NOTIFICAR VALOR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNotificarValor"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="12dp"
            android:text="Notificar valor"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="27dp"
            app:elevation="2dp" />

        <!-- CONFIRMAÇÃO ALUGUEL -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmacaoAluguel"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginBottom="20dp"
            android:text="Confirmar aluguel"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="27dp"
            app:elevation="2dp" />

        <!-- LINHA DIVISORA SUTIL -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="20dp"
            android:alpha="0.1"
            android:background="@color/black" />

        <!-- REMOVER REGISTRO (BOTÃO DE ALERTA) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRemoverRegistro"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:lineSpacingExtra="2dp"
            android:text="Remover registro\n(Ação irreversível)"
            android:textAlignment="center"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_red"
            app:cornerRadius="30dp"
            app:elevation="0dp"
            app:rippleColor="#40FFFFFF" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>