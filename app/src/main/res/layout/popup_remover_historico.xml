<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/textTituloPopupRemoverHistorico"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="REMOVER LIVRO"
        android:textColor="@color/biblio_blue"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- MENSAGEM (VERMELHA PARA AVISO DE REMOÇÃO) -->
    <TextView
        android:id="@+id/textMensagemPopupRemoverHistorico"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text='Tem certeza que deseja remover o livro "O Ceifador" do seu histórico?'
        android:textColor="@color/biblio_red"
        android:textSize="16sp" />

    <!-- BOTÃO PRIMÁRIO -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonPopupRemoverHistorico"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="Sim, remover"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="28dp"
        app:elevation="2dp" />

    <!-- BOTÃO CANCELAR -->
    <TextView
        android:id="@+id/textCancelarPopupRemoverHistorico"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:gravity="center"
        android:text="Cancelar"
        android:textColor="@color/biblio_red"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>