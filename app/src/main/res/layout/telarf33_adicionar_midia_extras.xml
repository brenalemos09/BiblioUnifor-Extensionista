<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- ====================================================== -->
    <!-- HEADER -->
    <!-- ====================================================== -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerAdicionarExtras"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO DECORATIVO -->

        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginStart="-90dp"
            android:layout_marginTop="-90dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO PERFIL -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFotoAdm"
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:layout_marginTop="50dp"
            android:layout_marginEnd="22dp"
            app:cardCornerRadius="37dp"
            app:cardElevation="3dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />

        </com.google.android.material.card.MaterialCardView>

        <!-- TÍTULO -->

        <TextView
            android:id="@+id/textTituloExtras"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Informações Extras"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardFotoAdm" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ====================================================== -->
    <!-- CONTEÚDO -->
    <!-- ====================================================== -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerAdicionarExtras">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="30dp">

            <!-- ================================================= -->
            <!-- QUANTIDADE DE PÁGINAS -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="@string/label_quantidade_paginas"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="1dp">

                <EditText
                    android:id="@+id/editQuantidadePaginas"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:hint="@string/hint_quantidade_paginas"
                    android:inputType="number"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/black"
                    android:textColorHint="#8A8A8A"
                    android:textSize="14sp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================= -->
            <!-- CATEGORIA -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="@string/label_categoria"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="1dp">

                <EditText
                    android:id="@+id/editCategoriaLivro"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:hint="@string/hint_categoria"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/black"
                    android:textColorHint="#8A8A8A"
                    android:textSize="14sp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================= -->
            <!-- EDITORA -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="@string/label_editora"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="1dp">

                <EditText
                    android:id="@+id/editEditoraLivro"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:hint="@string/hint_editora"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/black"
                    android:textColorHint="#8A8A8A"
                    android:textSize="14sp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================= -->
            <!-- LINK CAPA -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="@string/label_link_capa"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="1dp">

                <EditText
                    android:id="@+id/editLinkImagem"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:hint="@string/hint_link"
                    android:inputType="textUri"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:textColor="@color/black"
                    android:textColorHint="#8A8A8A"
                    android:textSize="14sp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================= -->
            <!-- SINOPSE -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="@string/label_sinopse"
                android:textColor="@color/black"
                android:textSize="17sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="115dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="1dp">

                <EditText
                    android:id="@+id/editSinopse"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:gravity="top"
                    android:hint="@string/hint_sinopse"
                    android:inputType="textMultiLine"
                    android:padding="16dp"
                    android:textColor="@color/black"
                    android:textColorHint="#8A8A8A"
                    android:textSize="14sp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================= -->
            <!-- BOTÃO -->
            <!-- ================================================= -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditarMaisInformacoes2"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_editar_mais_infos"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="28dp"
                app:elevation="4dp" />

        </LinearLayout>

    </ScrollView>



</androidx.constraintlayout.widget.ConstraintLayout>