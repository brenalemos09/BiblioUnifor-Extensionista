<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_popup_rounded"
    android:padding="28dp">

    <!-- BARRA SUPERIOR -->
    <View
        android:layout_width="45dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@color/gray_light"
        android:alpha="0.8"/>

    <!-- TÍTULO DO POPUP -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/titulo_filtrar_midia"
        android:textSize="24sp"
        android:fontFamily="sans-serif-black"
        android:textColor="@color/biblio_blue"
        android:layout_marginBottom="28dp"/>

    <!-- CAMPO TÍTULO -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_titulo"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textColor="@color/gray_medium"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/editTituloFiltro"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_input"
        android:hint="@string/hint_nome_titulo"
        android:paddingHorizontal="18dp"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:textColorHint="@color/gray_hint"
        android:inputType="text"
        android:importantForAutofill="no"
        android:singleLine="true"/>

    <!-- CAMPO AUTOR -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_autor"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textColor="@color/gray_medium"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/editAutorFiltro"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/bg_input"
        android:hint="@string/hint_nome_autor"
        android:paddingHorizontal="18dp"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:textColorHint="@color/gray_hint"
        android:inputType="text"
        android:importantForAutofill="no"
        android:singleLine="true"/>

    <!-- CAMPO ISBN -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_isbn"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:textColor="@color/gray_medium"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/editISBNFiltro"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_input"
        android:hint="@string/hint_isbn"
        android:paddingHorizontal="18dp"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:textColorHint="@color/gray_hint"
        android:inputType="text"
        android:importantForAutofill="no"
        android:singleLine="true"/>

    <!-- BOTÕES DE AÇÃO -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonSalvarFiltro"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/btn_salvar_filtro"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:fontFamily="sans-serif-black"
        android:textColor="@color/white"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="28dp"
        app:elevation="4dp"
        android:layout_marginBottom="12dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonLimparFiltro"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="@string/btn_limpar_filtragem"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/biblio_red"
        app:cornerRadius="26dp"/>

</LinearLayout>
