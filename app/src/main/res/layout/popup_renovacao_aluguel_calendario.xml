<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- ====================================================== -->
    <!-- CÍRCULO DECORATIVO TOPO -->
    <!-- ====================================================== -->

    <View
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="-120dp"
        android:layout_marginEnd="-60dp"
        android:alpha="0.18"
        android:background="@drawable/bg_circle"
        android:backgroundTint="@color/biblio_detalhes"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ====================================================== -->
    <!-- TÍTULO -->
    <!-- ====================================================== -->

    <TextView
        android:id="@+id/textTituloRenovacao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="72dp"
        android:text="Renovação de Aluguel"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ====================================================== -->
    <!-- SUBTÍTULO -->
    <!-- ====================================================== -->

    <TextView
        android:id="@+id/textSubtitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="26dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="26dp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:text="Por quantos dias a mais você deseja\nestender o aluguel desse livro?"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textTituloRenovacao" />

    <!-- ====================================================== -->
    <!-- CARD CALENDÁRIO -->
    <!-- ====================================================== -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardCalendario"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="26dp"
        android:layout_marginEnd="24dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="28dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textSubtitulo">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- LABEL -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data selecionada"
                android:textColor="#757575"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- DATA -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textDataSelecionada"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mon, Aug 17"
                    android:textColor="@color/black"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnEditarData"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Editar data"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_edit_pencil"
                    app:tint="@color/biblio_blue" />

            </LinearLayout>

            <!-- LINHA -->

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:alpha="0.1"
                android:background="@color/black" />

            <!-- MÊS -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textMesAno"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="August 2026"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnMesAnterior"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Mês anterior"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_chevron_left"
                    app:tint="@color/biblio_blue" />

                <ImageButton
                    android:id="@+id/btnProximoMes"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Próximo mês"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/biblio_blue" />

            </LinearLayout>

            <!-- CALENDÁRIO -->

            <CalendarView
                android:id="@+id/calendarViewRenovacao"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="8dp"
                android:firstDayOfWeek="2"
                android:showWeekNumber="false" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ====================================================== -->
    <!-- CÍRCULO DECORATIVO INFERIOR -->
    <!-- ====================================================== -->

    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginStart="-115dp"
        android:layout_marginBottom="-80dp"
        android:alpha="0.18"
        android:background="@drawable/bg_circle"
        android:backgroundTint="@color/biblio_detalhes"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ====================================================== -->
    <!-- BOTÃO -->
    <!-- ====================================================== -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmarRenovacao"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="60dp"
        android:text="Confirmar Renovação"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="28dp"
        app:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>