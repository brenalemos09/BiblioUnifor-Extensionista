<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- CAPA -->
        <LinearLayout
            android:id="@+id/layoutCapaAluguel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="90dp"
                android:layout_height="130dp"
                app:cardCornerRadius="8dp"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/imgCapaAluguel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/osda"
                    android:contentDescription="@string/desc_livro" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- INFOS + BOTÃO -->
        <LinearLayout
            android:id="@+id/layoutInfoAluguel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/layoutCapaAluguel"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/txtTituloAluguel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/biblio_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Título do Livro" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Devolução:"
                android:textStyle="bold"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtDataAluguel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:textSize="13sp"
                tools:text="15/05/2026" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status:"
                android:textStyle="bold"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtStatusAluguel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:textSize="13sp"
                tools:text="Disponível para renovação" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRenovarAluguel"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Renovar"
                android:textAllCaps="false"
                app:cornerRadius="24dp"
                app:backgroundTint="@color/biblio_blue" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
