<?xml version="1.0" encoding="utf-8"?>
<!-- Item de notificação para o RecyclerView da RF20.
     Mantém o visual premium dos cards existentes (corner 24dp, elevation 3dp). -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="32dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- CAPA DO LIVRO -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="85dp"
            android:layout_height="125dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/imgCapaItemNotif"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/osda"
                android:contentDescription="Capa do livro" />

        </com.google.android.material.card.MaterialCardView>

        <!-- INFORMAÇÕES DA NOTIFICAÇÃO -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Linha do título + checkbox "Lida" -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textTituloItemNotif"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Título do Livro"
                        android:textColor="@color/biblio_blue"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textAutorItemNotif"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Autor"
                        android:textColor="#415E5E"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- Badge "Lida" + CheckBox -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lida"
                        android:textColor="#415E5E"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/checkLidaItemNotif"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:buttonTint="@color/biblio_blue" />

                </LinearLayout>
            </LinearLayout>

            <!-- Descrição / mensagem -->
            <TextView
                android:id="@+id/textDescricaoItemNotif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="3dp"
                android:text="Mensagem da notificação"
                android:textColor="#415E5E"
                android:textSize="14sp" />

            <!-- Timestamp -->
            <TextView
                android:id="@+id/textTempoItemNotif"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="8dp"
                android:text="Hoje"
                android:textColor="#888888"
                android:textSize="12sp" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
