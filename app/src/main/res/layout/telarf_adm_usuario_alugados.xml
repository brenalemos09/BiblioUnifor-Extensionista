<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg"
    tools:context="com.example.bibliounifornew.adm.TelaRFAdmUsuarioAlugados">

    <!-- HEADER PREMIUM -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerAlugadosUsuario"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO DECORATIVO -->
        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginStart="-120dp"
            android:layout_marginTop="-120dp"
            android:alpha="0.15"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO DO USUÁRIO -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFotoUsuario"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="55dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/textNomeUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/nome_usuario"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardFotoUsuario" />

        <TextView
            android:id="@+id/textEmailUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/email_ronaldo"
            android:textColor="@color/white"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textNomeUsuario" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTEÚDO -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerAlugadosUsuario"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <!-- TÍTULO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/titulo_alugados"
                android:textColor="@color/biblio_blue"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <!-- CARD LIVRO 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- CAPA -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCapa1"
                        android:layout_width="80dp"
                        android:layout_height="110dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <ImageView
                            android:id="@+id/imageLivro1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/vidas_secas_capa" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- INFO -->
                    <TextView
                        android:id="@+id/textTituloLivro1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="@string/label_vidas_secas"
                        android:textColor="@color/biblio_blue"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/cardCapa1"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/textAutorLivro1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/autor_graciliano"
                        android:textColor="#415E5E"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@id/textTituloLivro1"
                        app:layout_constraintTop_toBottomOf="@id/textTituloLivro1" />

                    <TextView
                        android:id="@+id/textDataLabel1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/label_validade_aluguel"
                        android:textColor="#415E5E"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/textTituloLivro1"
                        app:layout_constraintTop_toBottomOf="@id/textAutorLivro1" />

                    <TextView
                        android:id="@+id/textDataLivro1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/data_exemplo_1"
                        android:textColor="#415E5E"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@id/textTituloLivro1"
                        app:layout_constraintTop_toBottomOf="@id/textDataLabel1" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CARD LIVRO 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- CAPA -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardCapa2"
                        android:layout_width="80dp"
                        android:layout_height="110dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <ImageView
                            android:id="@+id/imageLivro2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/o_alienista_capa" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- INFO -->
                    <TextView
                        android:id="@+id/textTituloLivro2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="@string/titulo_ceifador"
                        android:textColor="@color/biblio_blue"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/cardCapa2"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/textAutorLivro2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/autor_ceifador"
                        android:textColor="#415E5E"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@id/textTituloLivro2"
                        app:layout_constraintTop_toBottomOf="@id/textTituloLivro2" />

                    <TextView
                        android:id="@+id/textDataLabel2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/label_validade_aluguel"
                        android:textColor="#415E5E"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/textTituloLivro2"
                        app:layout_constraintTop_toBottomOf="@id/textAutorLivro2" />

                    <TextView
                        android:id="@+id/textDataLivro2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/data_exemplo_3"
                        android:textColor="#415E5E"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="@id/textTituloLivro2"
                        app:layout_constraintTop_toBottomOf="@id/textDataLabel2" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>