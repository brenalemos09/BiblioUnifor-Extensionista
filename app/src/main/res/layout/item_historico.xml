<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <!-- CARD PRINCIPAL -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <!-- CAPA DO LIVRO -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="80dp"
                android:layout_height="110dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">
                <ImageView
                    android:id="@+id/imgCapaHistorico"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/osda" />
            </com.google.android.material.card.MaterialCardView>

            <!-- INFO E BOTÃO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="16dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtTituloHistorico"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vida Secas"
                    android:textColor="@color/biblio_blue"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtAutorHistorico"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Graciliano Ramos"
                    android:textColor="#666666"
                    android:textSize="14sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRemoverHistorico"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:padding="0dp"
                    android:text="Remover do Histórico"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/biblio_red"
                    app:cornerRadius="20dp" />

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- LEGENDA ABAIXO DO CARD (Design da imagem) -->
    <TextView
        android:id="@+id/txtAcaoHistorico"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_status_historico"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:text="Solicitado aluguel de Vidas Secas (14 de mar.)"
        android:textColor="#555555"
        android:textSize="13sp" />

</LinearLayout>
