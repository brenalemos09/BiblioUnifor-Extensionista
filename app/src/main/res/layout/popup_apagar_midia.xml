<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="360dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    app:cardBackgroundColor="@color/biblio_bg"
    app:cardCornerRadius="28dp"
    app:cardElevation="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="32dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/textTituloApagar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/popup_apagar_midia_titulo"
            android:textColor="@color/biblio_blue"
            android:textSize="26sp"
            android:fontFamily="sans-serif-black"
            android:textStyle="bold" />

        <!-- SUBTÍTULO -->
        <TextView
            android:id="@+id/textDescricaoApagar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="@string/popup_apagar_midia_descricao"
            android:textAlignment="center"
            android:textColor="#555555"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />

        <!-- ERRO -->
        <TextView
            android:id="@+id/textErroSenha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/popup_apagar_midia_erro_senha"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- INPUT SENHA — TextInputLayout com toggle nativo -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/popup_apagar_midia_hint_senha"
            app:endIconMode="password_toggle"
            app:endIconContentDescription="@string/desc_ver_senha"
            app:boxCornerRadiusTopStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editSenhaAtual"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:textColor="@color/black"
                android:textColorHint="#A0A0A0"
                android:textSize="16sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- BOTÃO CONFIRMAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmarApagar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="@string/btn_confirmar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="sans-serif-black"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="28dp"
            app:elevation="6dp"
            app:rippleColor="#40FFFFFF" />

        <!-- BOTÃO CANCELAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelarApagar"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="@string/btn_cancelar"
            android:textAllCaps="false"
            android:textColor="@color/biblio_blue"
            android:textSize="16sp"
            app:cornerRadius="24dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
