<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Fundo decorativo Premium -->
        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginStart="-130dp"
            android:layout_marginTop="-130dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginEnd="-90dp"
            android:layout_marginTop="-40dp"
            android:alpha="0.10"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Logo -->
        <ImageView
            android:id="@+id/imageLogoAdm"
            android:layout_width="300dp"
            android:layout_height="150dp"
            android:layout_marginTop="40dp"
            android:adjustViewBounds="true"
            android:contentDescription="Logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- TÍTULO PRINCIPAL -->
        <TextView
            android:id="@+id/textTituloAdm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Acesse sua Conta ADM"
            android:textColor="@color/biblio_blue"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/imageLogoAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- BEM VINDO (Subtítulo Profissional) -->
        <TextView
            android:id="@+id/textBemVindoAdm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="Bem-vindo de volta!"
            android:textColor="#415E5E"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/textTituloAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- MENSAGEM DE ERRO (Ajustada) -->
        <TextView
            android:id="@+id/textErroAdm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Email ou senha incorretos\nPor favor, preencha todos os campos"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/textBemVindoAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- EMAIL (Pill Style) -->
        <EditText
            android:id="@+id/editEmailAdm"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input_pill"
            android:hint="Digite seu e-mail"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="24dp"
            android:textColor="@color/biblio_blue"
            android:textColorHint="#9E9E9E"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/textErroAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- SENHA (Pill Style) -->
        <RelativeLayout
            android:id="@+id/layoutSenhaAdm"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/editEmailAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/editSenhaAdm"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input_pill"
                android:hint="Digite sua senha"
                android:inputType="textPassword"
                android:paddingStart="24dp"
                android:paddingEnd="56dp"
                android:textColor="@color/biblio_blue"
                android:textColorHint="#9E9E9E"
                android:textSize="16sp"
                android:importantForAutofill="no" />

            <ImageView
                android:id="@+id/iconOlhoSenhaAdm"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:contentDescription="@string/desc_mostrar_ocultar_senha"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_eye_open"
                app:tint="@color/biblio_blue" />
        </RelativeLayout>

        <!-- CREDENCIAL (Pill Style) -->
        <EditText
            android:id="@+id/editCredencialAdm"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input_pill"
            android:hint="Digite sua credencial"
            android:inputType="text"
            android:paddingHorizontal="24dp"
            android:textColor="@color/biblio_blue"
            android:textColorHint="#9E9E9E"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/layoutSenhaAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ESQUECEU SENHA -->
        <TextView
            android:id="@+id/textEsqueceuSenhaAdm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Esqueceu a Senha?"
            android:textColor="@color/biblio_blue"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/editCredencialAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- BOTÃO ENTRAR (Pill Standard 56dp) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonEntrarAdm"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="32dp"
            android:text="Entrar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="28dp"
            app:elevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/textEsqueceuSenhaAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- CRIAR CONTA LINK -->
        <LinearLayout
            android:id="@+id/layoutCriarContaAdm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/buttonEntrarAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Não tem uma conta? "
                android:textColor="#415E5E"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/textCriarContaAdm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crie aqui"
                android:textColor="@color/biblio_blue"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Espaço final -->
        <Space
            android:layout_width="0dp"
            android:layout_height="60dp"
            app:layout_constraintTop_toBottomOf="@id/layoutCriarContaAdm"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>