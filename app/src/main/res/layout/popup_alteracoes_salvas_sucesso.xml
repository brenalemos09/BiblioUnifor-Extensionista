<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="28dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- ÍCONE DE SUCESSO (OPCIONAL, MAS BOM PARA UX) -->
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="16dp"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/biblio_blue" />

            <!-- TÍTULO -->
            <TextView
                android:id="@+id/textTituloSucesso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/msg_alteracoes_salvas"
                android:textColor="@color/biblio_blue"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- BOTÃO -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonVoltarPopup"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="32dp"
                android:text="@string/voltar"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="29dp"
                app:elevation="4dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>