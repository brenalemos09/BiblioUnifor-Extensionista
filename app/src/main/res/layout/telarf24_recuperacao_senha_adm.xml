<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Fundo decorativo Premium -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginStart="-100dp"
            android:layout_marginTop="-100dp"
            android:alpha="0.2"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/biblio_detalhes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Logo -->
        <ImageView
            android:id="@+id/imageLogoRecuperar"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="40dp"
            android:layout_marginHorizontal="40dp"
            android:contentDescription="Logo"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- TÍTULO PRINCIPAL -->
        <TextView
            android:id="@+id/textTituloRecuperar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Acesse sua Conta"
            android:textColor="@color/biblio_blue"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/imageLogoRecuperar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- SUBTÍTULO (Redefinir Senha) -->
        <TextView
            android:id="@+id/textSubtituloRecuperar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="Redefinir Senha"
            android:textColor="#415E5E"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/textTituloRecuperar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- DESCRIÇÃO -->
        <TextView
            android:id="@+id/textDescricaoRecuperar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="48dp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Insira abaixo o e-mail vinculado à sua conta administrativa."
            android:textColor="#5F6368"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/textSubtituloRecuperar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- MENSAGEM DE ERRO (Ajustada) -->
        <TextView
            android:id="@+id/textErroEmailRecuperar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="E-mail não cadastrado"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/textDescricaoRecuperar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- CAMPO EMAIL (Pill Style) -->
        <EditText
            android:id="@+id/editEmailRecuperar"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_input_pill"
            android:hint="Digite seu e-mail"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="24dp"
            android:textColor="@color/biblio_blue"
            android:textColorHint="#9E9E9E"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/textDescricaoRecuperar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- BOTÃO ENVIAR CÓDIGO (Pill Standard 56dp) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonEnviarCodigo"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="40dp"
            android:text="Enviar Código"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="28dp"
            app:elevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/editEmailRecuperar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- VOLTAR LOGIN -->
        <TextView
            android:id="@+id/textVoltarLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Retornar à tela de login"
            android:textColor="@color/biblio_blue"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/buttonEnviarCodigo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Espaço final -->
        <Space
            android:layout_width="0dp"
            android:layout_height="60dp"
            app:layout_constraintTop_toBottomOf="@id/textVoltarLogin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>