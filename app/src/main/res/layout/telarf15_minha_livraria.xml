<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerMinhaLivraria"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO DECORATIVO -->
        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginStart="-120dp"
            android:layout_marginTop="-120dp"
            android:alpha="0.15"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO DO USUÁRIO -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFotoUsuario"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="55dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imageUsuarioLivraria"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/textEmailLivraria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/email_usuario_exemplo"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardFotoUsuario" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTEÚDO SCROLLÁVEL -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerMinhaLivraria">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="40dp">

            <!-- TÍTULO MEUS LIVROS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_meus_livros"
                    android:textColor="@color/biblio_dark"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="12dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="@color/biblio_dark" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <ImageView
                    android:id="@+id/imgFiltroStatus"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="10dp"
                    android:src="@android:drawable/arrow_down_float"
                    app:tint="@color/biblio_dark" />
            </LinearLayout>

            <!-- ITEM 1: O ALIENISTA -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLivro1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cover1"
                        android:layout_width="90dp"
                        android:layout_height="130dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="2dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/o_alienista_capa" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/title1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="@string/titulo_livro"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/menu1"
                        app:layout_constraintStart_toEndOf="@id/cover1"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/author1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/autor_livro"
                        android:textColor="@color/biblio_dark"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="@id/title1"
                        app:layout_constraintStart_toStartOf="@id/title1"
                        app:layout_constraintTop_toBottomOf="@id/title1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/data_exemplo_1"
                        android:textColor="#999999"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/title1"
                        app:layout_constraintTop_toBottomOf="@id/author1" />

                    <TextView
                        android:id="@+id/menu1"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="@string/menu_opcoes_simbolo"
                        android:textColor="@color/black"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/labelAlugado1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_alugado"
                        android:textColor="@color/biblio_dark"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/status1"
                        app:layout_constraintStart_toStartOf="@id/title1" />

                    <TextView
                        android:id="@+id/status1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_lido"
                        android:textColor="@color/biblio_dark"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="@id/title1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRemover1"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="@string/btn_remover"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/biblio_blue"
                        app:cornerRadius="8dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ITEM 2: A SOCIEDADE DO ANEL -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLivro2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cover2"
                        android:layout_width="90dp"
                        android:layout_height="130dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="2dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/osda" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/title2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="@string/label_sociedade_anel"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/menu2"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toEndOf="@id/cover2" />

                    <TextView
                        android:id="@+id/author2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/autor_tolkien"
                        android:textColor="@color/biblio_dark"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="@id/title2"
                        app:layout_constraintStart_toStartOf="@id/title2"
                        app:layout_constraintTop_toBottomOf="@id/title2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/data_exemplo_2"
                        android:textColor="#999999"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/title2"
                        app:layout_constraintTop_toBottomOf="@id/author2" />

                    <TextView
                        android:id="@+id/menu2"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="@string/menu_opcoes_simbolo"
                        android:textColor="@color/black"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/status2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_nao_lido"
                        android:textColor="@color/biblio_dark"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="@id/title2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRemover2"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="@string/btn_remover"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/biblio_blue"
                        app:cornerRadius="8dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ITEM 3: VIDAS SECAS -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLivro3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cover3"
                        android:layout_width="90dp"
                        android:layout_height="130dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="2dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/vidas_secas_capa" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/title3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="@string/label_vidas_secas"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/menu3"
                        app:layout_constraintStart_toEndOf="@id/cover3"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/author3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/autor_graciliano"
                        android:textColor="@color/biblio_dark"
                        android:textSize="14sp"
                        app:layout_constraintEnd_toEndOf="@id/title3"
                        app:layout_constraintStart_toStartOf="@id/title3"
                        app:layout_constraintTop_toBottomOf="@id/title3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/data_exemplo_2"
                        android:textColor="#999999"
                        android:textSize="12sp"
                        app:layout_constraintStart_toStartOf="@id/title3"
                        app:layout_constraintTop_toBottomOf="@id/author3" />

                    <TextView
                        android:id="@+id/menu3"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="@string/menu_opcoes_simbolo"
                        android:textColor="@color/black"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/labelAlugado3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_alugado"
                        android:textColor="@color/biblio_dark"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toTopOf="@id/status3"
                        app:layout_constraintStart_toStartOf="@id/title3" />

                    <TextView
                        android:id="@+id/status3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_lendo"
                        android:textColor="@color/biblio_dark"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="@id/title3" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRemover3"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="@string/btn_remover"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/biblio_blue"
                        app:cornerRadius="8dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>