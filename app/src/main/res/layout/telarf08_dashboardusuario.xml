<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- ================= HEADER ================= -->

    <LinearLayout
        android:id="@+id/headerUsuario"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/biblio_detalhes"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <View
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginStart="-100dp"
                android:layout_marginTop="-100dp"
                android:background="@drawable/bg_circle"
                android:backgroundTint="@color/white"
                android:alpha="0.3"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp"
                android:layout_marginTop="16dp">

                <ImageView
                    android:id="@+id/btnNotificacao"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    android:contentDescription="@string/label_notificacao"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <ImageView
                    android:id="@+id/btnConfig"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@android:drawable/ic_menu_manage"
                    android:contentDescription="@string/label_configuracao"/>

            </LinearLayout>

        </FrameLayout>



        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imagePerfilUsuario"
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:src="@drawable/user_placeholder"
            android:layout_marginTop="-40dp"
            android:contentDescription="@string/label_perfil"/>



        <TextView
            android:id="@+id/textNomeUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nome_usuario"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"/>



        <TextView
            android:id="@+id/textBemVindoUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_bem_vindo"
            android:textColor="@color/white"/>

    </LinearLayout>




    <!-- ================= CONTEÚDO ================= -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerUsuario"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:orientation="vertical">



            <!-- CARD BEM VINDO -->

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_bem_vindo_caps"
                        android:textStyle="bold"/>


                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnProcurarLivros"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:text="@string/btn_procurar_livros"
                        app:backgroundTint="@color/biblio_dark"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>



            <!-- BOTÕES -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMinhaLivraria"
                android:text="@string/btn_minha_livraria"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                app:backgroundTint="@color/biblio_dark"/>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnListaDesejos"
                android:text="@string/btn_lista_desejos"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                app:backgroundTint="@color/biblio_dark"/>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAmigos"
                android:text="@string/titulo_amigos"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                app:backgroundTint="@color/biblio_dark"/>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistorico"
                android:text="@string/btn_historico"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                app:backgroundTint="@color/biblio_dark"/>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStatusAluguel"
                android:text="@string/btn_status_aluguel"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                app:backgroundTint="@color/biblio_dark"/>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSairConta"
                android:text="@string/btn_sair_conta"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                app:backgroundTint="@color/biblio_red"/>




            <!-- ================= DESCOBRIR ================= -->

            <TextView
                android:text="@string/label_descobrir"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>


            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">


                    <!-- LIVRO -->

                    <androidx.cardview.widget.CardView
                        android:layout_width="170dp"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp">

                            <ImageView
                                android:id="@+id/imgLivroAlienista"
                                android:layout_width="110dp"
                                android:layout_height="160dp"
                                android:src="@drawable/o_alienista_capa"
                                android:contentDescription="@string/desc_livro"/>


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/titulo_livro"
                                android:textStyle="bold"
                                android:textSize="18sp"/>


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/autor_machado"
                                android:textColor="#666"/>


                        </LinearLayout>

                    </androidx.cardview.widget.CardView>


                </LinearLayout>

            </HorizontalScrollView>


            <Space
                android:layout_width="match_parent"
                android:layout_height="80dp"/>


        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>