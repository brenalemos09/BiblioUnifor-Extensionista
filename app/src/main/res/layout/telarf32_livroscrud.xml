<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg"
    tools:context=".features.adm.gerenciamento.TelaRF32LivrosCRUD">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerVerificarMidia"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="230dp"
            android:layout_height="230dp"
            android:layout_marginStart="-90dp"
            android:layout_marginTop="-90dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_marginTop="-60dp"
            android:layout_marginEnd="70dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFotoAdm"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_marginTop="32dp"
            app:cardCornerRadius="41dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder"
                android:contentDescription="@string/desc_foto_adm_header" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/textTituloVerificarMidia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/titulo_gestao_midias"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardFotoAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBuscaMidias"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="-28dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/headerVerificarMidia"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_search_minimal"
                app:tint="@color/biblio_detalhes"
                android:contentDescription="@string/desc_icone_pesquisa_midia" />

            <EditText
                android:id="@+id/etProcurarMidia"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="@string/hint_pesquisar_midia"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:importantForAutofill="no"
                android:singleLine="true"
                android:textColor="@color/black"
                android:textColorHint="#8A8A8A"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/btnFiltro"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_filter_list"
                app:tint="@color/biblio_blue"
                android:contentDescription="@string/desc_filtro_lista" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- ÁREA DE CONTEÚDO (Otimizada: Removido NestedScrollView para permitir reciclagem do RecyclerView) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAdicionarMidia"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:text="@string/btn_adicionar_midia"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="16dp"
        app:elevation="0dp"
        app:icon="@drawable/ic_add_plus"
        app:iconGravity="textStart"
        app:layout_constraintTop_toBottomOf="@id/cardBuscaMidias"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/labelAcervoMidias"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"
        android:text="@string/label_acervo_midias"
        android:textColor="@color/biblio_dark"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnAdicionarMidia"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/txtAcervoVazio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:text="@string/msg_nenhuma_midia"
        android:textColor="#8A8A8A"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/labelAcervoMidias"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewMidias"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingHorizontal="24dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/labelAcervoMidias"
        app:layout_constraintBottom_toTopOf="@id/container_barra_tarefas" />

    <include
        android:id="@+id/container_barra_tarefas"
        layout="@layout/barra_tarefas_adm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
