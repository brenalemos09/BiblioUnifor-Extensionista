<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER (Premium Standard) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerSolicitacao"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO DECORATIVO PREMIUM -->
        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginStart="-130dp"
            android:layout_marginTop="-130dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- CAPA -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLivroSolicitacao"
            android:layout_width="120dp"
            android:layout_height="175dp"
            android:layout_marginStart="32dp"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imageLivroSolicitacao"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/o_alienista_capa" />

        </com.google.android.material.card.MaterialCardView>

        <!-- INFOS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="32dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cardLivroSolicitacao"
            app:layout_constraintTop_toTopOf="parent">

            <!-- TÍTULO -->
            <TextView
                android:id="@+id/textTituloLivroSolicitacao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/titulo_livro"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:textStyle="bold" />

            <!-- AUTOR -->
            <TextView
                android:id="@+id/textAutorLivroSolicitacao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/autor_machado"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:alpha="0.9" />

            <!-- GÊNERO -->
            <TextView
                android:id="@+id/textGeneroLivroSolicitacao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input_pill"
                android:backgroundTint="#26FFFFFF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="@string/genero_ficcao"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTEÚDO (Standard Padding 32dp) -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerSolicitacao"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="32dp"
            android:paddingBottom="40dp">

            <!-- BOTÃO PDF -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSolicitarPdf"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="@string/btn_solicitar_pdf"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="28dp"
                app:elevation="4dp" />

            <!-- BOTÃO BRAILLE -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSolicitarBraille"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="@string/btn_solicitar_braile"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="28dp"
                app:elevation="4dp" />

            <!-- BOTÃO AUDIOBOOK -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSolicitarAudiobook"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="@string/btn_solicitar_audiobook"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="28dp"
                app:elevation="4dp" />

            <!-- BOTÃO RESERVAR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonReservarLivro"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="@string/btn_reservar"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="28dp"
                app:elevation="4dp" />

            <!-- BOTÃO SETOR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSetorLocalizado"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_setor_localizado"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="28dp"
                app:elevation="4dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>