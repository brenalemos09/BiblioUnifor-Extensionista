<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER (Premium Standard) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerBuscaAmigos"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO DECORATIVO -->
        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginStart="-130dp"
            android:layout_marginTop="-130dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/textTituloBuscaAmigo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Adicionar Amigo"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTEÚDO TOPO (Standard Pading 32dp) -->
    <LinearLayout
        android:id="@+id/layoutTopoBusca"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="24dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/headerBuscaAmigos">

        <!-- INPUT PESQUISA -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPesquisaAmigo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="2dp"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp">

            <EditText
                android:id="@+id/editBuscarAmigo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Pesquisar por nome..."
                android:paddingHorizontal="24dp"
                android:textColor="@color/black"
                android:textColorHint="#415E5E"
                android:textSize="16sp"
                android:inputType="textPersonName" />

        </com.google.android.material.card.MaterialCardView>

        <!-- BOTÃO PROCURAR (Pill Standard) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonBuscarAmigo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="Procurar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="28dp"
            app:elevation="4dp" />

    </LinearLayout>

    <!-- RESULTADOS DINÂMICOS: usuários do Firestore (exceto self e já amigos) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewBuscaAmigos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:paddingBottom="40dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutTopoBusca" />

</androidx.constraintlayout.widget.ConstraintLayout>