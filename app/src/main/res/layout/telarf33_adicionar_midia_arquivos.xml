<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- ====================================================== -->
    <!-- HEADER -->
    <!-- ====================================================== -->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerAdicionarArquivos"
        android:layout_width="match_parent"
        android:layout_height="175dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO DECORATIVO -->

        <View
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginStart="-70dp"
            android:layout_marginTop="-70dp"
            android:alpha="0.14"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO PERFIL -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFotoAdm"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="18dp"
            app:cardCornerRadius="32dp"
            app:cardElevation="3dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />

        </com.google.android.material.card.MaterialCardView>

        <!-- TÍTULO -->

        <TextView
            android:id="@+id/textTituloTela"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Arquivos e Mídia"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ====================================================== -->
    <!-- CONTEÚDO -->
    <!-- ====================================================== -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerAdicionarArquivos">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="18dp"
            android:paddingEnd="16dp"
            android:paddingBottom="28dp">

            <!-- ================================================= -->
            <!-- PDF -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="Arquivo PDF:"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="1dp">

                <EditText
                    android:id="@+id/editArquivoPdf"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center_vertical"
                    android:hint="Caminho ou link do PDF..."
                    android:inputType="textUri"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/black"
                    android:textColorHint="#8A8A8A"
                    android:textSize="14sp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================= -->
            <!-- AUDIOBOOK -->
            <!-- ================================================= -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="7dp"
                android:text="Arquivo Audiobook:"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="1dp">

                <EditText
                    android:id="@+id/editArquivoAudiobook"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center_vertical"
                    android:hint="Caminho ou link do Audiobook..."
                    android:inputType="textUri"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/black"
                    android:textColorHint="#8A8A8A"
                    android:textSize="14sp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================= -->
            <!-- BRAILLE -->
            <!-- ================================================= -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="260dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/checkBraille"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:minWidth="48dp"
                    android:minHeight="48dp"
                    android:buttonTint="@color/biblio_blue"
                    android:gravity="center"
                    android:padding="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Disponível em Braille"
                    android:textColor="@color/black"
                    android:textSize="17sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- ================================================= -->
            <!-- BOTÃO -->
            <!-- ================================================= -->

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSalvarLivro"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Salvar novo livro"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="28dp"
                app:elevation="4dp" />

        </LinearLayout>

    </ScrollView>



</androidx.constraintlayout.widget.ConstraintLayout>