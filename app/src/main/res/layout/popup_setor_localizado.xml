<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="32dp"
    android:paddingVertical="44dp">

    <!-- TÍTULO DELICADO -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LOCALIZAÇÃO"
        android:textColor="@color/biblio_blue"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.2"
        android:alpha="0.45" />

    <!-- SETOR COM TIPOGRAFIA REFINADA -->
    <TextView
        android:id="@+id/textSetorLocalizado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="SETOR X"
        android:textColor="@color/biblio_dark"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="-0.01" />

    <!-- DIVISOR SUTIL -->
    <View
        android:layout_width="32dp"
        android:layout_height="1.5dp"
        android:layout_marginTop="16dp"
        android:background="@color/biblio_blue"
        android:alpha="0.12" />

    <!-- MENSAGEM SUAVE -->
    <TextView
        android:id="@+id/textLivroSetor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Livro: O Alienista"
        android:textColor="#888888"
        android:textSize="14sp"
        android:lineSpacingExtra="2dp" />

    <!-- BOTÃO ELEGANTE -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonVoltarSetor"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="32dp"
        android:text="Voltar"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="25dp"
        app:elevation="0dp"
        app:rippleColor="#33FFFFFF" />

</LinearLayout>