<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER (Premium Standard) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerAmigos"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO DECORATIVO -->
        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginStart="-130dp"
            android:layout_marginTop="-130dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO USUÁRIO (Circular) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFotoUsuario"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="55dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imageUsuario"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />

        </com.google.android.material.card.MaterialCardView>

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/textTituloAmigos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Amigos"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardFotoUsuario"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ÁREA ADICIONAR AMIGOS (Pill Aesthetic) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layoutAdicionarAmigos"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerAmigos">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="@color/white">

            <ImageView
                android:id="@+id/btnAdicionarAmigo"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="4dp"
                android:src="@drawable/ic_add_plus"
                app:tint="@color/biblio_blue" />

            <TextView
                android:id="@+id/textAdicionarAmigos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Adicionar Amigos"
                android:textColor="@color/biblio_blue"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- CONTEÚDO SCROLLÁVEL: solicitações pendentes + lista de amigos -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layoutAdicionarAmigos"
        app:layout_constraintBottom_toTopOf="@id/barraUsuario">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingBottom="100dp">

            <!-- SEÇÃO: Solicitações de Amizade (GONE por padrão; aparece se houver pendências) -->
            <TextView
                android:id="@+id/textSolicitacoesTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"
                android:text="Solicitações de Amizade"
                android:textColor="@color/biblio_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewSolicitacoes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone" />

            <View
                android:id="@+id/dividerSolicitacoes"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="@color/biblio_detalhes"
                android:visibility="gone" />

            <!-- SEÇÃO: Amigos confirmados -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:text="Meus Amigos"
                android:textColor="@color/biblio_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewAmigos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- BARRA DE TAREFAS FIXA -->
    <include
        android:id="@+id/barraUsuario"
        layout="@layout/barra_tarefas_usuario"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>