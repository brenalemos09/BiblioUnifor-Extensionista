<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Fundo decorativo Premium -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginStart="-100dp"
            android:layout_marginTop="-100dp"
            android:alpha="0.2"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/biblio_detalhes"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- TÍTULO PRINCIPAL -->
        <TextView
            android:id="@+id/textTituloCadastroAdm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:layout_marginHorizontal="32dp"
            android:gravity="center"
            android:text="Seja bem-vindo ao\nBiblioUnifor!"
            android:textColor="@color/biblio_blue"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- SUBTÍTULO -->
        <TextView
            android:id="@+id/textSubtituloCadastroAdm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="Vamos criar sua conta de Administrador"
            android:textColor="#415E5E"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/textTituloCadastroAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- CAMPO NOME COMPLETO (Pill Style) -->
        <EditText
            android:id="@+id/editNomeCompletoAdm"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_input_pill"
            android:hint="Digite seu nome completo"
            android:paddingHorizontal="24dp"
            android:textColor="@color/biblio_blue"
            android:textColorHint="#9E9E9E"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/textSubtituloCadastroAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- CAMPO NOME USUÁRIO (Pill Style) -->
        <EditText
            android:id="@+id/editNomeUsuarioAdm"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input_pill"
            android:hint="Digite seu nome de usuário"
            android:paddingHorizontal="24dp"
            android:textColor="@color/biblio_blue"
            android:textColorHint="#9E9E9E"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/editNomeCompletoAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- MENSAGEM DE ERRO EMAIL -->
        <TextView
            android:id="@+id/textErroEmailAdmCadastro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="16dp"
            android:text="E-mail já cadastrado ou inválido"
            android:textColor="@color/biblio_red"
            android:textSize="13sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/editNomeUsuarioAdm"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- CAMPO EMAIL (Pill Style) -->
        <EditText
            android:id="@+id/editEmailAdmCadastro"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_pill"
            android:hint="Digite seu e-mail"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="24dp"
            android:textColor="@color/biblio_blue"
            android:textColorHint="#9E9E9E"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/textErroEmailAdmCadastro"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- MENSAGEM DE ERRO CREDENCIAL -->
        <TextView
            android:id="@+id/textErroCredencialAdm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="16dp"
            android:text="Credencial já cadastrada ou inválida"
            android:textColor="@color/biblio_red"
            android:textSize="13sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/editEmailAdmCadastro"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- CAMPO CREDENCIAL (Pill Style) -->
        <EditText
            android:id="@+id/editCredencialAdmCadastro"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_pill"
            android:hint="Digite sua credencial"
            android:paddingHorizontal="24dp"
            android:textColor="@color/biblio_blue"
            android:textColorHint="#9E9E9E"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/textErroCredencialAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- MENSAGENS DE ERRO SENHA -->
        <TextView
            android:id="@+id/textErroSenha1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="16dp"
            android:text="Campo obrigatório"
            android:textColor="@color/biblio_red"
            android:textSize="13sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/editCredencialAdmCadastro"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- CAMPO SENHA (Pill Style) -->
        <RelativeLayout
            android:id="@+id/layoutSenhaAdmCadastro"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/textErroSenha1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/editSenhaAdmCadastro"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input_pill"
                android:hint="Digite sua senha"
                android:inputType="textPassword"
                android:paddingStart="24dp"
                android:paddingEnd="56dp"
                android:textColor="@color/biblio_blue"
                android:textColorHint="#9E9E9E"
                android:textSize="16sp"
                android:importantForAutofill="no" />

            <ImageView
                android:id="@+id/iconOlhoSenhaAdmCadastro"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:contentDescription="@string/desc_mostrar_ocultar_senha"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_eye_closed"
                app:tint="@color/biblio_blue"/>
        </RelativeLayout>

        <TextView
            android:id="@+id/textErroSenha2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="16dp"
            android:text="Campo obrigatório"
            android:textColor="@color/biblio_red"
            android:textSize="13sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layoutSenhaAdmCadastro"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- CAMPO CONFIRMAR SENHA (Pill Style) -->
        <RelativeLayout
            android:id="@+id/layoutConfirmarSenhaAdm"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/textErroSenha2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/editConfirmarSenhaAdm"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input_pill"
                android:hint="Confirme sua senha"
                android:inputType="textPassword"
                android:paddingStart="24dp"
                android:paddingEnd="56dp"
                android:textColor="@color/biblio_blue"
                android:textColorHint="#9E9E9E"
                android:textSize="16sp"
                android:importantForAutofill="no" />

            <ImageView
                android:id="@+id/iconOlhoConfirmarSenhaAdm"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:contentDescription="@string/desc_mostrar_ocultar_senha"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_eye_closed"
                app:tint="@color/biblio_blue"/>
        </RelativeLayout>

        <!-- REGRAS E AVISOS DE SENHA -->
        <TextView
            android:id="@+id/textRegrasSenhaAdm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="20dp"
            android:lineSpacingExtra="2dp"
            android:text="• A senha deve conter pelo menos 8 caracteres\n• Um número\n• Uma letra maiúscula"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layoutConfirmarSenhaAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/textErroSenhaDiferente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="8dp"
            android:text="As senhas estão diferentes"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/textRegrasSenhaAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/textErroSenhaIgual"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="4dp"
            android:text="A senha é igual à anterior"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/textErroSenhaDiferente"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- BOTÃO CRIAR (Pill Standard 56dp) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCriarContaAdm"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="32dp"
            android:text="Criar Conta"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="28dp"
            app:elevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/textErroSenhaIgual"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- JÁ TEM CONTA? LINK -->
        <LinearLayout
            android:id="@+id/layoutEntreAquiAdm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/buttonCriarContaAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Já tem uma conta? "
                android:textColor="#415E5E"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/textEntreAquiAdm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entre aqui"
                android:textColor="@color/biblio_blue"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Espaço final -->
        <Space
            android:layout_width="0dp"
            android:layout_height="60dp"
            app:layout_constraintTop_toBottomOf="@id/layoutEntreAquiAdm"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>